rules_version = '2';

// MindBloom: authenticated users may only read/write their own user document tree.
// Public mindfulness catalog is read-only for signed-in users (managed in Console).
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection=**}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /mindfulnessResources/{resourceId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
